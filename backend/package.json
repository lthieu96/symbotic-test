{
  "name": "robot-fleet-backend",
  "version": "1.0.0",
  "description": "Robot Fleet Management Backend with uWebSockets.js",
  "packageManager": "pnpm@10.30.3",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "simulator": "tsx src/simulator/robot-simulator.ts",
    "simulator:prod": "node dist/simulator/robot-simulator.js",
    "cluster": "node dist/cluster.js",
    "cluster:dev": "tsx src/cluster.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.11.1",
    "mongodb": "^6.0.0",
    "mongoose": "^8.14.2",
    "uWebSockets.js": "uNetworking/uWebSockets.js#v20.67.0",
    "ws": "^8.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.8",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "websocket",
    "mongodb",
    "uws",
    "real-time",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
