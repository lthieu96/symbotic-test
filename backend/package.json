{
  "name": "robot-fleet-backend",
  "version": "1.0.0",
  "description": "Robot Fleet Management Backend with uWebSockets.js",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "simulator": "tsx src/simulator/robot-simulator.ts",
    "simulator:prod": "node dist/simulator/robot-simulator.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "uWebSockets.js": "uNetworking/uWebSockets.js#v20.33.0",
    "mongodb": "^6.0.0",
    "mongoose": "^8.14.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.8",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "websocket",
    "mongodb",
    "uws",
    "real-time",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
