# Backend server
PORT=8080
MONGO_URI=mongodb://localhost:27017/robot-fleet
# Raw telemetry TTL in seconds (default 7 days)
TELEMETRY_RETENTION_SECONDS=604800

# Clustering (npm run cluster / cluster:dev)
# REDIS_URL enables the cross-worker event bus; leave empty for single-process dev.
REDIS_URL=redis://localhost:6379
# Number of workers; 0 → use the CPU count
WORKERS=0

# Robot simulator (npm run simulator)
SERVER_URL=ws://localhost:8080
ROBOT_COUNT=5
